<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_dental_patient" model="ir.actions.act_window">
            <field name="name">Patients</field>
            <field name="res_model">dental.patient</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
        </record>

        <menuitem id="menu_dental_root" name="Dental Clinic" sequence="10"/>
        <menuitem id="menu_dental_patient" name="Patients" parent="menu_dental_root" action="action_dental_patient" sequence="1"/>

        <record id="view_dental_patient_tree" model="ir.ui.view">
            <field name="name">dental.patient.tree</field>
            <field name="model">dental.patient</field>
            <field name="arch" type="xml">
                <tree decoration-success="state == 'done'" decoration-info="state == 'in_progress'" decoration-muted="state == 'new'">
                    <field name="name"/>
                    <field name="age"/>
                    <field name="phone"/>
                    <field name="treatment_category"/>
                    <field name="cost"/>
                    <field name="amount_paid"/>
                    <field name="remaining_amount"/>
                    <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state == 'in_progress'" decoration-muted="state == 'new'"/>
                </tree>
            </field>
        </record>

        <record id="view_dental_patient_form" model="ir.ui.view">
            <field name="name">dental.patient.form</field>
            <field name="model">dental.patient</field>
            <field name="arch" type="xml">
                <form string="Dental Patient">
                    <header>
                        <button name="action_start_treatment" string="Start Treatment" type="object" class="btn-primary" invisible="state != 'new'"/>
                        <button name="action_complete_treatment" string="Complete" type="object" class="btn-success" invisible="state != 'in_progress'"/>
                        <field name="state" widget="statusbar" statusbar_visible="new,in_progress,done"/>
                    </header>
                    <sheet>
                        <div style="background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%); padding: 40px; border-radius: 20px; min-height: 100vh;">
                            <div style="text-align: center; margin-bottom: 30px;">
                                <h1 style="color: #1565c0; font-size: 36px; font-weight: bold; text-shadow: 2px 2px 4px rgba(0,0,0,0.1);">Dental Clinic</h1>
                                <p style="color: #64b5f6; font-size: 16px;">Patient Registration and Treatment Management</p>
                            </div>

                            <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(21, 101, 192, 0.1); margin-bottom: 25px;">
                                <h2 style="color: #1565c0; font-size: 24px; margin-bottom: 25px; border-bottom: 3px solid #64b5f6; padding-bottom: 10px;">Patient Information</h2>
                                <group>
                                    <group>
                                        <field name="first_name" placeholder="Enter first name" style="font-size: 16px; padding: 12px;"/>
                                    </group>
                                    <group>
                                        <field name="last_name" placeholder="Enter last name" style="font-size: 16px; padding: 12px;"/>
                                    </group>
                                </group>
                                <group>
                                    <group>
                                        <field name="age" style="font-size: 16px; padding: 12px;"/>
                                    </group>
                                    <group>
                                        <field name="phone" placeholder="Enter phone number" style="font-size: 16px; padding: 12px;"/>
                                    </group>
                                </group>
                            </div>

                            <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(21, 101, 192, 0.1); margin-bottom: 25px;">
                                <h2 style="color: #1565c0; font-size: 24px; margin-bottom: 25px; border-bottom: 3px solid #64b5f6; padding-bottom: 10px;">Treatment Details</h2>
                                <group>
                                    <field name="treatment_category" widget="radio" options="{'horizontal': true}"/>
                                </group>
                                <group invisible="treatment_category != 'fixe'">
                                    <field name="fixe_type" widget="radio" options="{'horizontal': true}"/>
                                </group>
                                <group invisible="treatment_category != 'amovible'">
                                    <field name="amovible_type" widget="radio" options="{'horizontal': true}"/>
                                </group>
                                <group invisible="amovible_type != 'partielle'">
                                    <field name="partielle_subtype" widget="radio" options="{'horizontal': true}"/>
                                </group>
                            </div>

                            <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(21, 101, 192, 0.1); margin-bottom: 25px; border: 2px solid #42a5f5;">
                                <h2 style="color: #1565c0; font-size: 24px; margin-bottom: 25px; border-bottom: 3px solid #64b5f6; padding-bottom: 10px;">Simple Treatments</h2>
                                <group>
                                    <field name="simple_treatment" widget="radio" options="{'horizontal': true}"/>
                                </group>
                            </div>

                            <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(21, 101, 192, 0.1); margin-bottom: 25px; border: 2px solid #1565c0;">
                                <h2 style="color: #1565c0; font-size: 24px; margin-bottom: 25px; border-bottom: 3px solid #64b5f6; padding-bottom: 10px;">Teeth Selection (Universal Numbering 1-32)</h2>
                                <p style="color: #64b5f6; font-size: 14px; margin-bottom: 15px; text-align: center;">Click on teeth numbers to select/deselect</p>
                                
                                <!-- SVG Dental Chart with inline CSS -->
                                <div style="text-align: center; background: #f8fbff; padding: 15px; border-radius: 10px; margin-bottom: 15px;">
                                    <svg id="dental-chart" viewBox="0 0 500 600" style="max-width: 100%; height: 450px;">
                                        <style>
                                            .dc-tooth { cursor: pointer; }
                                            .dc-tooth ellipse { fill: #ffffff; stroke: #1565c0; stroke-width: 2; transition: all 0.2s; }
                                            .dc-tooth text { font-size: 11px; font-weight: bold; fill: #1565c0; pointer-events: none; }
                                            .dc-tooth:hover ellipse { fill: #e3f2fd; stroke-width: 3; }
                                            .dc-tooth.selected ellipse { fill: #1565c0; stroke: #0d47a1; stroke-width: 3; }
                                            .dc-tooth.selected text { fill: #ffffff; }
                                        </style>
                                        
                                        <text x="250" y="25" text-anchor="middle" font-size="16" font-weight="bold" fill="#1565c0">Universal Numbering System (1-32)</text>
                                        <line x1="250" y1="40" x2="250" y2="560" stroke="#bbdefb" stroke-width="2" stroke-dasharray="8,4"/>
                                        <text x="250" y="55" text-anchor="middle" font-size="14" font-weight="bold" fill="#64b5f6">UPPER JAW</text>
                                        
                                        <!-- Upper Right 1-8 -->
                                        <g class="dc-tooth" data-tooth="1" transform="translate(420, 80)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">1</text></g>
                                        <g class="dc-tooth" data-tooth="2" transform="translate(420, 130)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">2</text></g>
                                        <g class="dc-tooth" data-tooth="3" transform="translate(415, 180)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">3</text></g>
                                        <g class="dc-tooth" data-tooth="4" transform="translate(405, 230)"><ellipse cx="0" cy="0" rx="20" ry="24"/><text x="0" y="4" text-anchor="middle">4</text></g>
                                        <g class="dc-tooth" data-tooth="5" transform="translate(390, 275)"><ellipse cx="0" cy="0" rx="20" ry="24"/><text x="0" y="4" text-anchor="middle">5</text></g>
                                        <g class="dc-tooth" data-tooth="6" transform="translate(370, 315)"><ellipse cx="0" cy="0" rx="20" ry="24"/><text x="0" y="4" text-anchor="middle">6</text></g>
                                        <g class="dc-tooth" data-tooth="7" transform="translate(345, 350)"><ellipse cx="0" cy="0" rx="18" ry="22"/><text x="0" y="4" text-anchor="middle">7</text></g>
                                        <g class="dc-tooth" data-tooth="8" transform="translate(315, 380)"><ellipse cx="0" cy="0" rx="18" ry="22"/><text x="0" y="4" text-anchor="middle">8</text></g>
                                        
                                        <!-- Upper Left 9-16 -->
                                        <g class="dc-tooth" data-tooth="9" transform="translate(185, 380)"><ellipse cx="0" cy="0" rx="18" ry="22"/><text x="0" y="4" text-anchor="middle">9</text></g>
                                        <g class="dc-tooth" data-tooth="10" transform="translate(155, 350)"><ellipse cx="0" cy="0" rx="18" ry="22"/><text x="0" y="4" text-anchor="middle">10</text></g>
                                        <g class="dc-tooth" data-tooth="11" transform="translate(130, 315)"><ellipse cx="0" cy="0" rx="20" ry="24"/><text x="0" y="4" text-anchor="middle">11</text></g>
                                        <g class="dc-tooth" data-tooth="12" transform="translate(110, 275)"><ellipse cx="0" cy="0" rx="20" ry="24"/><text x="0" y="4" text-anchor="middle">12</text></g>
                                        <g class="dc-tooth" data-tooth="13" transform="translate(95, 230)"><ellipse cx="0" cy="0" rx="20" ry="24"/><text x="0" y="4" text-anchor="middle">13</text></g>
                                        <g class="dc-tooth" data-tooth="14" transform="translate(85, 180)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">14</text></g>
                                        <g class="dc-tooth" data-tooth="15" transform="translate(80, 130)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">15</text></g>
                                        <g class="dc-tooth" data-tooth="16" transform="translate(80, 80)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">16</text></g>
                                        
                                        <text x="250" y="420" text-anchor="middle" font-size="14" font-weight="bold" fill="#64b5f6">LOWER JAW</text>
                                        
                                        <!-- Lower Left 17-24 -->
                                        <g class="dc-tooth" data-tooth="17" transform="translate(80, 450)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">17</text></g>
                                        <g class="dc-tooth" data-tooth="18" transform="translate(80, 500)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">18</text></g>
                                        <g class="dc-tooth" data-tooth="19" transform="translate(85, 545)"><ellipse cx="0" cy="0" rx="22" ry="24"/><text x="0" y="4" text-anchor="middle">19</text></g>
                                        <g class="dc-tooth" data-tooth="20" transform="translate(110, 575)"><ellipse cx="0" cy="0" rx="20" ry="22"/><text x="0" y="4" text-anchor="middle">20</text></g>
                                        <g class="dc-tooth" data-tooth="21" transform="translate(140, 590)"><ellipse cx="0" cy="0" rx="20" ry="22"/><text x="0" y="4" text-anchor="middle">21</text></g>
                                        <g class="dc-tooth" data-tooth="22" transform="translate(175, 595)"><ellipse cx="0" cy="0" rx="18" ry="20"/><text x="0" y="4" text-anchor="middle">22</text></g>
                                        <g class="dc-tooth" data-tooth="23" transform="translate(210, 595)"><ellipse cx="0" cy="0" rx="18" ry="20"/><text x="0" y="4" text-anchor="middle">23</text></g>
                                        <g class="dc-tooth" data-tooth="24" transform="translate(245, 590)"><ellipse cx="0" cy="0" rx="18" ry="20"/><text x="0" y="4" text-anchor="middle">24</text></g>
                                        
                                        <!-- Lower Right 25-32 -->
                                        <g class="dc-tooth" data-tooth="25" transform="translate(280, 590)"><ellipse cx="0" cy="0" rx="18" ry="20"/><text x="0" y="4" text-anchor="middle">25</text></g>
                                        <g class="dc-tooth" data-tooth="26" transform="translate(315, 595)"><ellipse cx="0" cy="0" rx="18" ry="20"/><text x="0" y="4" text-anchor="middle">26</text></g>
                                        <g class="dc-tooth" data-tooth="27" transform="translate(350, 590)"><ellipse cx="0" cy="0" rx="20" ry="22"/><text x="0" y="4" text-anchor="middle">27</text></g>
                                        <g class="dc-tooth" data-tooth="28" transform="translate(380, 575)"><ellipse cx="0" cy="0" rx="20" ry="22"/><text x="0" y="4" text-anchor="middle">28</text></g>
                                        <g class="dc-tooth" data-tooth="29" transform="translate(405, 545)"><ellipse cx="0" cy="0" rx="22" ry="24"/><text x="0" y="4" text-anchor="middle">29</text></g>
                                        <g class="dc-tooth" data-tooth="30" transform="translate(415, 500)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">30</text></g>
                                        <g class="dc-tooth" data-tooth="31" transform="translate(420, 450)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">31</text></g>
                                        <g class="dc-tooth" data-tooth="32" transform="translate(420, 400)"><ellipse cx="0" cy="0" rx="22" ry="26"/><text x="0" y="4" text-anchor="middle">32</text></g>
                                    </svg>
                                </div>
                                
                                <!-- Hidden checkboxes for data storage (no visual display) -->
                                <field name="tooth_ids" widget="many2many_checkboxes" options="{'no_create': true}" invisible="1"/>
                            </div>

                            <div style="background: linear-gradient(135deg, #fff3e0 0%, #ffffff 100%); padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(255, 152, 0, 0.1); margin-bottom: 25px; border: 2px solid #ffe0b2;">
                                <h2 style="color: #e65100; font-size: 24px; margin-bottom: 25px; border-bottom: 3px solid #ffb74d; padding-bottom: 10px;">Payment Information</h2>
                                <group>
                                    <group>
                                        <field name="cost" string="Total Price (DZD)" style="font-size: 16px; padding: 12px;"/>
                                    </group>
                                    <group>
                                        <field name="amount_paid" string="Amount Paid (DZD)" style="font-size: 16px; padding: 12px;"/>
                                    </group>
                                </group>
                                <div style="background: #ffebee; padding: 15px; border-radius: 10px; margin-top: 20px; border: 1px solid #ef5350;">
                                    <h3 style="color: #c62828; margin: 0; font-size: 18px;">
                                        <strong>Remaining Amount:</strong> <field name="remaining_amount" readonly="1" style="font-size: 20px; color: #c62828; font-weight: bold;"/> DZD
                                        <span invisible="remaining_amount == 0" style="color: #ef5350; font-size: 14px;"> - Unpaid</span>
                                        <span invisible="remaining_amount != 0" style="color: #4caf50; font-size: 14px;"> - Paid</span>
                                    </h3>
                                </div>
                            </div>

                            <div style="text-align: center; margin-bottom: 25px;" invisible="state != 'new'">
                                <button name="action_start_treatment" string="Start Treatment" type="object" class="btn-primary" style="font-size: 18px; padding: 15px 40px; border-radius: 10px;"/>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
