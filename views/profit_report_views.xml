<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_profit_report_form" model="ir.ui.view">
        <field name="name">dental.profit.report.form</field>
        <field name="model">dental.profit.report</field>
        <field name="arch" type="xml">
            <form string="Profit Report">
                <div style="background: linear-gradient(135deg, #e3f2fd 0%, #ffffff 100%); padding: 30px; border-radius: 20px; min-height: 500px;">
                    <div style="text-align: center; margin-bottom: 40px;">
                        <h1 style="color: #1565c0; font-size: 42px; font-weight: bold; margin: 0;">Profit Report</h1>
                        <p style="color: #64b5f6; font-size: 18px; margin-top: 10px;">Monthly Revenue and Cost Analysis</p>
                    </div>

                    <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(21, 101, 192, 0.1); margin-bottom: 25px;">
                        <h2 style="color: #1565c0; font-size: 24px; margin-bottom: 25px; border-bottom: 3px solid #64b5f6; padding-bottom: 10px;">Select Period</h2>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                            <div>
                                <span style="color: #1565c0; font-size: 16px; font-weight: 600; display: block; margin-bottom: 8px;">Start Date</span>
                                <field name="start_date"/>
                            </div>
                            <div>
                                <span style="color: #1565c0; font-size: 16px; font-weight: 600; display: block; margin-bottom: 8px;">End Date</span>
                                <field name="end_date"/>
                            </div>
                        </div>
                        <div style="margin-top: 20px;">
                            <button name="action_calculate" string="Calculate Profit" type="object" class="btn-primary" style="font-size: 16px; padding: 10px 30px; border-radius: 8px;"/>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; text-align: center;">
                        <div style="background: linear-gradient(135deg, #e3f2fd 0%, #ffffff 100%); padding: 25px; border-radius: 15px; box-shadow: 0 4px 15px rgba(21, 101, 192, 0.1);">
                            <div style="color: #1565c0; font-size: 16px; font-weight: 600; margin-bottom: 10px;">Total Revenue</div>
                            <field name="total_revenue" style="font-size: 28px; font-weight: bold; color: #1565c0;"/>
                        </div>
                        <div style="background: linear-gradient(135deg, #ffebee 0%, #ffffff 100%); padding: 25px; border-radius: 15px; box-shadow: 0 4px 15px rgba(198, 40, 40, 0.1); border: 1px solid #ffcdd2;">
                            <div style="color: #c62828; font-size: 16px; font-weight: 600; margin-bottom: 10px;">Total Cost</div>
                            <field name="total_cost" style="font-size: 28px; font-weight: bold; color: #c62828;"/>
                        </div>
                        <div style="background: linear-gradient(135deg, #e8f5e9 0%, #ffffff 100%); padding: 25px; border-radius: 15px; box-shadow: 0 4px 15px rgba(46, 125, 50, 0.1); border: 1px solid #c8e6c9;">
                            <div style="color: #2e7d32; font-size: 16px; font-weight: 600; margin-bottom: 10px;">Net Profit</div>
                            <field name="net_profit" style="font-size: 28px; font-weight: bold; color: #2e7d32;"/>
                        </div>
                    </div>
                </div>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_profit_report" model="ir.actions.act_window">
        <field name="name">Profit Report</field>
        <field name="res_model">dental.profit.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_dental_profit" name="Profit Report" parent="menu_dental_root" action="action_profit_report" sequence="3"/>
</odoo>
